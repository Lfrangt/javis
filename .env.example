OPENAI_API_KEY=

# Local API
JAVIS_API_PORT=3417
JAVIS_DATA_DIR=
JAVIS_TOGGLE_HOTKEY=Control+Shift+Space
JAVIS_SUMMON_HOTKEY=Alt+Space
# Alias for summon hotkey if you prefer "tap" naming. Set either value to false to disable.
JAVIS_TAP_HOTKEY=
JAVIS_CAPTURE_HOTKEY=Control+Shift+I
JAVIS_WINDOW_PARK_CORNER=notch
JAVIS_WINDOW_PARK_DISPLAY=primary
JAVIS_WINDOW_PARK_MARGIN=24
JAVIS_WINDOW_NOTCH_TOP_OFFSET=5
JAVIS_NOTIFICATIONS=true
JAVIS_MAX_PERSISTED_INBOX=300
JAVIS_MAX_PERSISTED_SESSIONS=200
JAVIS_AMBIENT_OBSERVE=false
JAVIS_AMBIENT_CAPTURE_SCREEN=false
JAVIS_AMBIENT_INTERVAL_MS=8000
JAVIS_AMBIENT_LEARNING=false
JAVIS_AMBIENT_LEARNING_INTERVAL_MS=60000
JAVIS_INCLUDE_LEARNING_IN_PROMPTS=true
# Optional export target for generated local Codex skills. Empty defaults to ~/.agents/skills.
JAVIS_USER_SKILLS_DIR=
JAVIS_AUTOPILOT_ENABLED=false
JAVIS_AUTOPILOT_INTERVAL_MS=120000
JAVIS_MAX_RECOVERY_JOB_ATTEMPTS=2
JAVIS_MAX_PERSISTED_AMBIENT=500
JAVIS_MAX_LEARNING_SOURCE_EVENTS=200
JAVIS_MAX_PERSISTED_COLLABORATION_CLAIMS=200
JAVIS_COLLABORATION_CLAIM_TTL_MS=1800000
# Optional Chrome DevTools bridge for browser DOM control when Chrome Apple Events JavaScript is off.
JAVIS_CHROME_DEBUG_PORT=9222

# Model lanes
OPENAI_REALTIME_MODEL=gpt-realtime-2
OPENAI_REALTIME_VOICE=marin
JAVIS_WAKE_WORDS=JAVIS,Jarvis,贾维斯,小贾
JAVIS_WAKE_TRIGGER_TTL_MS=10000
JAVIS_CONVERSATION_STALE_MS=120000
JAVIS_REALTIME_PREFLIGHT_CONTEXT=true
VITE_JAVIS_REALTIME_WORK_PROGRESS_SYNC_MS=30000
# Optional: command that prints a line containing "wake" or one configured wake word.
JAVIS_WAKE_ENGINE_CMD=
OPENAI_FAST_MODEL=gpt-5.4-mini
OPENAI_BACKGROUND_MODEL=gpt-5.5
OPENAI_VISION_MODEL=gpt-5.4-mini

# Local automation safety
JAVIS_ENABLE_LOCAL_EXEC=false
JAVIS_TRUSTED_LOCAL_MODE=false
JAVIS_ACTION_DRY_RUN=false
JAVIS_MAX_AUTO_RISK_LEVEL=2
JAVIS_REQUIRE_APPROVAL_AT_RISK_LEVEL=3
JAVIS_ALLOWED_WRITE_ROOTS=

# Optional worker command overrides
JAVIS_CODEX_CMD=codex exec
JAVIS_CLAUDE_CMD=claude -p
JAVIS_ALLOWED_CLI_COMMANDS=codex,claude,gh,git,npm,pnpm,yarn,bun,node,npx,python,python3,uv
